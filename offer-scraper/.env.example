# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
# Use the anon key (if you set up the permissive RLS policy) or the service key
SUPABASE_KEY=your-anon-or-service-role-key

# ── Period to scrape ─────────────────────────────────────────────────────────
PERIOD=Verano 2025/2026
PERIOD_CODE=202530

# ── USFQ credentials (optional – only used by --login for auto-fill) ─────────
